version: '3.9'

services:

  # ── Tier 1: MySQL Database ─────────────────────────────────────────────────
  mysql:
    build:
      context: ./mysql
      dockerfile: Dockerfile
    container_name: greenleaf_mysql
    restart: unless-stopped
    environment:
      MYSQL_ROOT_PASSWORD: rootpassword
      MYSQL_DATABASE: gardening_db
      MYSQL_USER: gardenuser
      MYSQL_PASSWORD: gardenpass
    volumes:
      - mysql_data:/var/lib/mysql
      - ./mysql/init.sql:/docker-entrypoint-initdb.d/init.sql
    networks:
      - greenleaf_net
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "root", "-prootpassword"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
